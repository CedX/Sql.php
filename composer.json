{
	"description": "A simple micro-ORM, based on PDO and data annotations.",
	"homepage": "https://github.com/CedX/Sql.php",
	"license": "MIT",
	"name": "cedx/sql",
	"type": "library",
	"version": "0.1.0",
	"authors": [
		{"email": "cedx@outlook.com", "homepage": "https://cedric-belin.fr", "name": "Cédric Belin"}
	],
	"autoload": {
		"files": ["Sources/Functions.php"],
		"psr-4": {"Belin\\Sql\\": "Sources/"}
	},
	"autoload-dev": {
		"psr-4": {"Belin\\Sql\\": "Tests/"}
	},
	"config": {
		"platform-check": false
	},
	"keywords": [
		"data",
		"database",
		"mapper",
		"mapping",
		"orm",
		"pdo",
		"query",
		"sql"
	],
	"require": {
		"php": ">=8.5.0"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.2.2",
		"phpunit/phpunit": "^13.2.1"
	},
	"support": {
		"docs": "https://github.com/CedX/Sql.php/tree/main/Documentation",
		"issues": "https://github.com/CedX/Sql.php/issues"
	}
}
